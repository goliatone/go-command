{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vitest/globals", "vite/client"],
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["src", "tests", "demo", "vite.config.ts", "vite.demo.config.ts", "../../src"]
}
