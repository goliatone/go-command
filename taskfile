#!/bin/bash

# Check for -debug flag
if [[ $* == *-debug* ]]; then
    set -x
fi

export LGR_NO_TIMESTAMP=true

VERSION_FILE="./.version"

# If we have a .taskenv file load it as source
# the file should be e.g.
# #!/bin/bash
# export DATABASE_URL="..."
if [ -f .taskenv ]; then
    # shellcheck disable=SC1091
    source .taskenv
fi

# This makes all bin packages installed via npm available here
# e.g. bogota, nyc, autocannon, etc.
PATH=$(pwd)/node_modules/.bin:$PATH

# This will make all scripts available in the ./src/bin directory
PATH=$(pwd)/src/bin:$PATH


#################################################
# Development dependencies
#################################################

function _install:lgr {
    mkdir -p bin
    if hash lgr 2>/dev/null; then
        lgr OK "lgr already installed..."
    else
        echo "Installing lgr"
        brew tap goliatone/homebrew-tap
        brew install lgr
        lgr OK "lgr installed..."
    fi
}

function _install:changelog {
    if git-cliff lgr 2>/dev/null; then
        lgr OK "git-cliff already installed..."
    else
        echo "Installing lgr"
        brew install brew install orhun/git-cliff/git-cliff
        lgr OK "git-cliff installed..."
    fi
}

function _install:brew {
    if [[ $(command -v brew) == "" ]]; then
        lgr I "Installing Hombrew"
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
    else
        lgr I "Updating Homebrew"
        brew update
    fi
}

function _install:envset {
    if hash envset 2>/dev/null; then
        lgr OK "envset installed..."
    else
        lgr I "Installing envset..."
        brew install envset
        lgr OK "envset installed..."
    fi
}

##########################################
# Application management
##########################################

function dev:install {
    cd "$(pwd)/src" || exit "$?"

    _install:lgr
    _install:brew

    _install:envset
    _install:changelog

    lgr ok "dependencies intalled..."
}

function dev:env:load {
    eval "$(envset development --isolated=true)"
}

function dev:test {
    lgr exec -- go test ./...
}

function dev:test:cross {
    local tmp
    local command_root
    local job_root

    command_root=$(pwd)
    job_root="$(cd ../go-job && pwd)"
    tmp=$(mktemp -d)

    cat > "${tmp}/go.work" <<EOF
go 1.23.4
use (
    ${command_root}
    ${job_root}
)
EOF

    lgr I "cross-check go-command flow contracts"
    GOWORK="${tmp}/go.work" go test ./flow/... || return 1

    lgr I "cross-check go-job queue command bridge and worker runtime"
    (
        cd "${job_root}" || exit "$?"
        GOWORK="${tmp}/go.work" go test ./queue/command ./queue/worker
    ) || return 1
}

function dev:test:race {
    lgr exec -- go test ./... -race -count=1
}

function dev:test:race:registry {
    lgr exec -- go test ./registry -race -count=1
}

# Run flow package tests
function flow:test {
    lgr exec -- go test ./flow/...
}

function _client:core:packages {
    echo "rpc fsm fsm-rpc"
}

function _client:builder:packages {
    echo "fsm-ui-builder"
}

function _client:release:packages {
    echo "$(_client:core:packages) $(_client:builder:packages)"
}

function _client:build:workspace {
    local client_dir
    local pkg

    client_dir=$1
    pkg=$2

    (
        cd "${client_dir}" || exit "$?"
        npm run build --workspace "packages/${pkg}"
    ) || return 1
}

##
## -----
##
## client:release
##
## Keep client package versions in sync with the root .version file.
##
## Arguments:
## @arg 1 {string} [tag=<root .version>]
function client:release {
    local tag
    local pkg
    local pkgs
    local pkg_file

    tag=${1:-$(version:get)}
    if [ -z "$tag" ]; then
        echo "missing version tag"
        return 1
    fi

    if ! command -v node >/dev/null 2>&1; then
        echo "node is required for client:release"
        return 1
    fi

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:release lockfile sync"
        return 1
    fi

    node -e 'const fs=require("fs"); const path="client/package.json"; const version=process.argv[1]; const json=JSON.parse(fs.readFileSync(path,"utf8")); json.version=version; fs.writeFileSync(path, JSON.stringify(json, null, 2)+"\n");' "${tag}" || return 1

    pkgs=$(_client:release:packages)
    for pkg in $pkgs; do
        pkg_file="client/packages/${pkg}/package.json"
        node -e 'const fs=require("fs"); const path=process.argv[1]; const version=process.argv[2]; const json=JSON.parse(fs.readFileSync(path,"utf8")); json.version=version; fs.writeFileSync(path, JSON.stringify(json, null, 2)+"\n");' "${pkg_file}" "${tag}" || return 1
    done

    (
        cd client || exit "$?"
        npm install --package-lock-only
    ) || return 1
}

##
## -----
##
## client:build
##
## Build core TS client packages and sync dist output into embedded Go assets (`data/client`).
function client:build {
    local client_dir
    local pkgs
    local pkg
    local output_dir

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:build"
        return 1
    fi

    client_dir="$(pwd)/client"
    output_dir="$(pwd)/data/client"

    if [ ! -d "${client_dir}/node_modules" ]; then
        (
            cd "${client_dir}" || exit "$?"
            npm ci
        ) || return 1
    fi

    pkgs=$(_client:core:packages)
    for pkg in $pkgs; do
        _client:build:workspace "${client_dir}" "${pkg}" || return 1
    done

    rm -rf "${output_dir}"
    mkdir -p "${output_dir}"

    for pkg in $pkgs; do
        mkdir -p "${output_dir}/${pkg}"
        cp -R "${client_dir}/packages/${pkg}/dist/." "${output_dir}/${pkg}/"
        if [ ! -f "${output_dir}/${pkg}/index.js" ]; then
            echo "client build output is missing ${output_dir}/${pkg}/index.js"
            return 1
        fi
    done
}

##
## -----
##
## client:build:builder
##
## Build FSM UI builder package and sync dist output into optional embedded Go assets (`data/client-builder`).
function client:build:builder {
    local client_dir
    local pkgs
    local pkg
    local output_root
    local output_dir

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:build:builder"
        return 1
    fi

    client_dir="$(pwd)/client"
    output_root="$(pwd)/data/client-builder"

    if [ ! -d "${client_dir}/node_modules" ]; then
        (
            cd "${client_dir}" || exit "$?"
            npm ci
        ) || return 1
    fi

    pkgs=$(_client:builder:packages)
    for pkg in $pkgs; do
        _client:build:workspace "${client_dir}" "${pkg}" || return 1

        output_dir="${output_root}/${pkg}"
        rm -rf "${output_dir}"
        mkdir -p "${output_dir}"
        cp -R "${client_dir}/packages/${pkg}/dist/." "${output_dir}/"

        if [ ! -f "${output_dir}/index.js" ]; then
            echo "builder build output is missing ${output_dir}/index.js"
            return 1
        fi

        if [ -f "${client_dir}/packages/${pkg}/dist/index.css" ] && [ ! -f "${output_dir}/index.css" ]; then
            echo "builder build output is missing ${output_dir}/index.css"
            return 1
        fi
    done
}

function client:test {
    client_dir="$(pwd)/client"

    pkgs=$(_client:builder:packages)
    for pkg in $pkgs; do
        _client:build:workspace "${client_dir}" "${pkg}" || return 1

        cd "${client_dir}/packages/${pkg}/" || return 1

        npm test
    done
}

##
## -----
##
## client:build:all
##
## Build core client packages and builder package artifacts.
function client:build:all {
    client:build || return 1
    client:build:builder || return 1
}

##
## -----
##
## client:build:example:fsm_ui_builder_web_chat
##
## Build only the client packages required by the FSM UI Builder web chat example:
## - `fsm` -> sync to `data/client/fsm`
## - `fsm-ui-builder` -> sync to `data/client-builder/fsm-ui-builder`
##
## Use this while iterating locally so the example serves latest changed artifacts.
function client:build:example:fsm_ui_builder_web_chat {
    local client_dir
    local fsm_output
    local builder_output

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:build:example:fsm_ui_builder_web_chat"
        return 1
    fi

    client_dir="$(pwd)/client"
    if [ ! -d "${client_dir}/node_modules" ]; then
        (
            cd "${client_dir}" || exit "$?"
            npm ci
        ) || return 1
    fi

    _client:build:workspace "${client_dir}" "fsm" || return 1
    _client:build:workspace "${client_dir}" "fsm-ui-builder" || return 1

    fsm_output="$(pwd)/data/client/fsm"
    rm -rf "${fsm_output}"
    mkdir -p "${fsm_output}"
    cp -R "${client_dir}/packages/fsm/dist/." "${fsm_output}/"
    if [ ! -f "${fsm_output}/index.js" ]; then
        echo "example client build output is missing ${fsm_output}/index.js"
        return 1
    fi

    builder_output="$(pwd)/data/client-builder/fsm-ui-builder"
    rm -rf "${builder_output}"
    mkdir -p "${builder_output}"
    cp -R "${client_dir}/packages/fsm-ui-builder/dist/." "${builder_output}/"
    if [ ! -f "${builder_output}/index.js" ]; then
        echo "example builder build output is missing ${builder_output}/index.js"
        return 1
    fi
    if [ -f "${client_dir}/packages/fsm-ui-builder/dist/index.css" ] && [ ! -f "${builder_output}/index.css" ]; then
        echo "example builder build output is missing ${builder_output}/index.css"
        return 1
    fi
}

##
## -----
##
## example:fsm_ui_builder_web_chat:run
##
## Build required client artifacts and run the FSM UI Builder web chat example.
function example:fsm_ui_builder_web_chat:run {
    client:build:example:fsm_ui_builder_web_chat || return 1
    (
        cd examples/fsm_ui_builder_web_chat || exit "$?"
        /Users/goliatone/.g/go/bin/go run .
    ) || return 1
}

function go:mod:update {
    local modules
    local extra=()
    local mod
    local root
    local latest
    local root_latest
    local resolved
    local current_mod

    if ! command -v rg >/dev/null 2>&1; then
        lgr ERR "rg is required to list goliatone modules"
        return 1
    fi

    # Get current module name to exclude from updates (avoid self-update and submodules)
    current_mod=$(go list -m)

    modules=$(rg -o 'github.com/goliatone/[^[:space:]]+' go.mod | sort -u | grep -v "^${current_mod}")
    if [ -z "$modules" ]; then
        lgr ERR "no goliatone modules found in go.mod"
        return 1
    fi

    lgr I "updating goliatone modules to latest..."
    for mod in $modules; do
        latest=""
        resolved=0
        if latest=$(go list -m -u -f '{{if .Update}}{{.Update.Version}}{{else}}{{.Version}}{{end}}' "$mod" 2>/dev/null); then
            resolved=1
        fi

        if [ "$resolved" -eq 1 ] && [ -n "$latest" ]; then
            lgr I "go get ${mod}@${latest}"
            go get "${mod}@${latest}" || return 1
            continue
        fi

        lgr WARN "failed to resolve latest for ${mod}, trying ${mod}@latest"
        if go get -u "${mod}@latest"; then
            continue
        fi

        root=$(echo "$mod" | awk -F/ '{print $1"/"$2"/"$3}')
        if [ "$root" != "$mod" ]; then
            root_latest=""
            if root_latest=$(go list -m -u -f '{{if .Update}}{{.Update.Version}}{{else}}{{.Version}}{{end}}' "$root" 2>/dev/null); then
                lgr WARN "failed to update ${mod}, retrying ${root}@${root_latest}"
                go get "${root}@${root_latest}" || return 1
            else
                lgr WARN "failed to resolve ${root}, retrying ${root}@latest"
                go get -u "${root}@latest" || return 1
            fi
        else
            return 1
        fi
    done

    if [ "$#" -gt 0 ]; then
        for mod in "$@"; do
            extra+=("${mod}@latest")
        done
        lgr I "updating extra modules: ${extra[*]}"
        go get -u "${extra[@]}" || return 1
    fi

    go mod tidy
}

##
## ########################################
##           Version Management
## ########################################

##
## -----
##
## version:upsert
##
## Save version to meta file.
## First time will create file if not present
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:upsert {
    local tag=${1}

    if [ -z "$tag" ]; then
        version:get
    else
        version:set "$tag"
        version:get
    fi
}

##
## -----
##
## version:get
##
## Get version from meta file.
function version:get {

    test -f "${VERSION_FILE}" || touch "${VERSION_FILE}"

    local tag
    tag=$(cat "${VERSION_FILE}")

    if [ -z "$tag" ]; then
        tag="0.0.1"
        version:set "$tag"
    fi

    echo -n "$tag"
}

##
## -----
##
## version:set
##
## Set and save version to meta file.
## First time will create file if not present.
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:set {

    local tag
    tag=${1}
    if [ -z "$tag" ]; then
        exit 1
    fi

    version:check

    echo -e "$tag" > "${VERSION_FILE}"
}

##
## -----
##
## version:bump
## Bump sem ver by specifying a level.
## Valid levels are:
## - patch (default)
## - minor
## - major
##
## If you want to update the .version file
## pass the `--write` flag.
## @see https://github.com/fsaintjacques/semver-tool/blob/master/src/semver
##
## @arg 1 {string} [level=patch]
## Outputs:
##   Semver string "$major.$minor.$patch"
##
## @flag --write Will write to .version file
##
function version:bump {

    version:check

    # Default values
    level='patch'
    write_to_file=0

    # Parse options
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --write)
                write_to_file=1
                shift
            ;;
            patch|minor|major)
                level=$1
                shift
            ;;
            *)
                echo "Invalid option: $1"
                return 2
            ;;
        esac
    done

    # Read contents of version and store in
    IFS='.' read -ra identifiers < "$VERSION_FILE"

    [[ "${#identifiers[@]}" -ne 3 ]] && echo "Invalid semver string" && return 1

    patch=${identifiers[2]}
    minor=${identifiers[1]}
    major=${identifiers[0]}

    case $level in
        patch)
            patch=$((patch+1))
        ;;
        minor)
            minor=$((minor+1))
            patch=0
        ;;
        major)
            major=$((major+1))
            minor=0
            patch=0
        ;;
        *)
            echo "Invalid level passed"
            return 2
    esac

    new_version="$major.$minor.$patch"

    if [[ $write_to_file -eq 1 ]]; then
        echo "$new_version" > "${VERSION_FILE}"
    else
        echo "$new_version"
    fi
}

function version:check {
    if [ ! -f "$VERSION_FILE" ]; then
        echo "0.0.0" > "$VERSION_FILE"
    fi
}


##
## -----
##
## release
##
## Bump our current version, create a git tag
## and push to trigger our release flow.
##
## Arguments:
## @arg 1 {string} [level=patch]
##        Accepted major, minor, patch
function release {
    local tag
    local level
    local message

    # Fetch all changes from origin
    git fetch --all

    if [ -f ".version" ]; then
        # Make sure we have the latest version file
        git checkout origin/main -- ".version"
    else
        lgr I "File .version does not exist. Skipping."
    fi

    # Pull tags to make sure we have
    git pull --tags -f

    level=${1:-"patch"}

    # Bump our version
    tag=$(version:bump "${level}")

    # Set message: default to New major|minor|patch release: vx.x.x
    message=${2:-"New ${level} release: v${tag}"}

    # Update version file
    version:set "${tag}"

    # Keep TS client package version and embedded dist in sync with release tag.
    client:release "${tag}" || return 1
    client:build:all || return 1

    # Add updated version file to git
    git add "${VERSION_FILE}"
    if [ -f "client/package.json" ]; then
        git add client/package.json client/package-lock.json client/packages/*/package.json
    fi
    if [ -d "data/client" ]; then
        git add data/client
    fi
    if [ -d "data/client-builder" ]; then
        git add data/client-builder
    fi
    git commit -m "Bump version: v${tag}"

    # Create a new tag
    git tag -a "v${tag}" -m "${message}"

    # Push tags and trigger release 🚀 🥳
    git push --tags
    git push

    # Generate changelog
    git cliff --output CHANGELOG.md
    git add CHANGELOG.md
    git commit -m "docs: update changelog for v${tag}"

    git push
}

