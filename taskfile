function dev:test:cross {
    local tmp
    local command_root
    local job_root

    command_root=$(pwd)
    job_root="$(cd ../go-job && pwd)"
    tmp=$(mktemp -d)

    cat > "${tmp}/go.work" <<EOF
go 1.23.4
use (
    ${command_root}
    ${job_root}
)
EOF

    lgr I "cross-check go-command flow contracts"
    GOWORK="${tmp}/go.work" go test ./flow/... || return 1

    lgr I "cross-check go-job queue command bridge and worker runtime"
    (
        cd "${job_root}" || exit "$?"
        GOWORK="${tmp}/go.work" go test ./queue/command ./queue/worker
    ) || return 1
}

