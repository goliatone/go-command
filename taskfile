##
## client:build:example:fsm_ui_builder_web_chat
##
## Build only the client packages required by the FSM UI Builder web chat example:
## - `fsm` -> sync to `data/client/fsm`
## - `fsm-ui-builder` -> sync to `data/client-builder/fsm-ui-builder`
##
## Use this while iterating locally so the example serves latest changed artifacts.
function client:build:example:fsm_ui_builder_web_chat {
    local client_dir
    local fsm_output
    local builder_output

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:build:example:fsm_ui_builder_web_chat"
        return 1
    fi

    client_dir="$(pwd)/client"
    if [ ! -d "${client_dir}/node_modules" ]; then
        (
            cd "${client_dir}" || exit "$?"
            npm ci
        ) || return 1
    fi

