##
## -----
##
## client:release
##
## Keep client package versions in sync with the root .version file.
##
## Arguments:
## @arg 1 {string} [tag=<root .version>]
function client:release {
    local tag
    local pkg
    local pkgs
    local pkg_file

    tag=${1:-$(version:get)}
    if [ -z "$tag" ]; then
        echo "missing version tag"
        return 1
    fi

    if ! command -v node >/dev/null 2>&1; then
        echo "node is required for client:release"
        return 1
    fi

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:release lockfile sync"
        return 1
    fi

    node -e 'const fs=require("fs"); const path="client/package.json"; const version=process.argv[1]; const json=JSON.parse(fs.readFileSync(path,"utf8")); json.version=version; fs.writeFileSync(path, JSON.stringify(json, null, 2)+"\n");' "${tag}" || return 1

    pkgs=$(_client:release:packages)
    for pkg in $pkgs; do
        pkg_file="client/packages/${pkg}/package.json"
        node -e 'const fs=require("fs"); const path=process.argv[1]; const version=process.argv[2]; const json=JSON.parse(fs.readFileSync(path,"utf8")); json.version=version; fs.writeFileSync(path, JSON.stringify(json, null, 2)+"\n");' "${pkg_file}" "${tag}" || return 1
    done

    (
        cd client || exit "$?"
        npm install --package-lock-only
    ) || return 1
}

##
## -----
##
## client:build
##
## Build core TS client packages and sync dist output into embedded Go assets (`data/client`).
function client:build {
    local client_dir
    local pkgs
    local pkg
    local output_dir

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:build"
        return 1
    fi

    client_dir="$(pwd)/client"
    output_dir="$(pwd)/data/client"

    if [ ! -d "${client_dir}/node_modules" ]; then
        (
            cd "${client_dir}" || exit "$?"
            npm ci
        ) || return 1
    fi

    pkgs=$(_client:core:packages)
    for pkg in $pkgs; do
        _client:build:workspace "${client_dir}" "${pkg}" || return 1
    done

    rm -rf "${output_dir}"
    mkdir -p "${output_dir}"

    for pkg in $pkgs; do
        mkdir -p "${output_dir}/${pkg}"
        cp -R "${client_dir}/packages/${pkg}/dist/." "${output_dir}/${pkg}/"
        if [ ! -f "${output_dir}/${pkg}/index.js" ]; then
            echo "client build output is missing ${output_dir}/${pkg}/index.js"
            return 1
        fi
    done
}

##
## -----
##
## client:build:builder
##
## Build FSM UI builder package and sync dist output into optional embedded Go assets (`data/client-builder`).
function client:build:builder {
    local client_dir
    local pkgs
    local pkg
    local output_root
    local output_dir

    if ! command -v npm >/dev/null 2>&1; then
        echo "npm is required for client:build:builder"
        return 1
    fi

    client_dir="$(pwd)/client"
    output_root="$(pwd)/data/client-builder"

    if [ ! -d "${client_dir}/node_modules" ]; then
        (
            cd "${client_dir}" || exit "$?"
            npm ci
        ) || return 1
    fi

    pkgs=$(_client:builder:packages)
    for pkg in $pkgs; do
        _client:build:workspace "${client_dir}" "${pkg}" || return 1

        output_dir="${output_root}/${pkg}"
        rm -rf "${output_dir}"
        mkdir -p "${output_dir}"
        cp -R "${client_dir}/packages/${pkg}/dist/." "${output_dir}/"

        if [ ! -f "${output_dir}/index.js" ]; then
            echo "builder build output is missing ${output_dir}/index.js"
            return 1
        fi

        if [ -f "${client_dir}/packages/${pkg}/dist/index.css" ] && [ ! -f "${output_dir}/index.css" ]; then
            echo "builder build output is missing ${output_dir}/index.css"
            return 1
        fi
    done
}

function client:test {
    client_dir="$(pwd)/client"

    pkgs=$(_client:builder:packages)
    for pkg in $pkgs; do
        _client:build:workspace "${client_dir}" "${pkg}" || return 1

        cd "${client_dir}/packages/${pkg}/" || return 1

        npm test
    done
}

##
## -----
##
## client:build:all
##
## Build core client packages and builder package artifacts.
function client:build:all {
    client:build || return 1
    client:build:builder || return 1
}

##
